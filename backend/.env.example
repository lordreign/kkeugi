# Local development env. Copy to .env and customize.
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kkeugi
JWT_SECRET=local-dev-secret-replace-with-openssl-rand-hex-32

# Google OAuth — only needed for real Google Sign-In. Local dev can use /v1/auth/dev/login instead.
GOOGLE_CLIENT_ID=dev-google-client-id-not-set

# Optional — leave empty in dev unless testing LLM/Sentry
ANTHROPIC_API_KEY=
SENTRY_DSN_BACKEND=
